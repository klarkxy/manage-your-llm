# ManageYourLLM 环境变量示例
# 复制为 .env 后按需修改。

NODE_ENV=development
MYLLM_HOST=0.0.0.0
MYLLM_PORT=5420
MYLLM_LOG_LEVEL=info
MYLLM_LOG_FILE=./logs/app.log
MYLLM_DATABASE_URL=file:./data/manageyourllm.sqlite

# 生产环境必须修改以下三项默认值！
MYLLM_SECRET_KEY=change-me-in-production
MYLLM_ADMIN_USERNAME=admin
MYLLM_ADMIN_PASSWORD=change-me-on-first-run
MYLLM_ADMIN_DISPLAY_NAME=Admin

# 反代信任设置（空字符串表示不信任任何上游 hop）
MYLLM_TRUST_PROXY=

# 对外 base URL（为空时回退到 http://localhost:${MYLLM_PORT}）
MYLLM_PUBLIC_BASE_URL=
