# ModelHarbor environment template.
#
# Copy to `.env` (or set in your process manager / container env) and
# adjust. Only the variables that have a value different from the
# baked-in default need to be set.
#
# In production, MODELHARBOR_SECRET_KEY and MODELHARBOR_ADMIN_PASSWORD
# MUST be changed. Starting the server with either still set to the
# default value throws an error before the listener is bound.

# Runtime: "production" turns on stricter validation and rejects the
# default secrets. "development" (default) and "test" are permissive.
# NODE_ENV=production

# Network bind address and port for the API + bundled dashboard.
# MODELHARBOR_HOST=0.0.0.0
# MODELHARBOR_PORT=5420

# SQLite (libSQL) database location. Use `file:<path>` for a local
# file. The parent directory will be created on first start.
# MODELHARBOR_DATABASE_URL=file:./data/modelharbor.sqlite

# Symmetric key used to encrypt stored upstream provider keys and to
# sign admin session cookies. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be at least 32 bytes. Rotating this value invalidates all
# stored upstream keys and active admin sessions.
# MODELHARBOR_SECRET_KEY=replace-me-with-a-random-32-byte-hex-string

# First admin bootstrap. Created on first run if no admin exists yet.
# In production both the username and password are required to differ
# from their defaults.
# MODELHARBOR_ADMIN_USERNAME=admin
# MODELHARBOR_ADMIN_PASSWORD=replace-me-with-a-strong-password
# MODELHARBOR_ADMIN_DISPLAY_NAME=Admin

# Pino log level and file sink. Set LOG_FILE to "-" or "1" to disable
# the file sink (stdout only).
# MODELHARBOR_LOG_LEVEL=info
# MODELHARBOR_LOG_FILE=./logs/app.log

# Trust-proxy forwarding (Fastify `trustProxy`). Required when running
# behind nginx / Cloudflare / Caddy / a load balancer so that
# `req.ip`, the per-IP login rate limit, and the audit log all reflect
# the real client. Accepts:
#   ""              — do not trust any hop (default, direct binding)
#   "loopback"      — 127.0.0.1, ::1, ::ffff:127.0.0.1
#   "linklocal"     — 169.254.0.0/16
#   "uniquelocal"   — 10/8, 172.16/12, 192.168/16, fc00::/7
#   "true"          — trust every hop
#   "1"             — trust only the first hop
#   "10.0.0.0/8,192.168.0.0/16" — comma-separated CIDR list
# MODELHARBOR_TRUST_PROXY=loopback

# Non-production only. Set to 1 to make the API process serve the
# built web bundle as well, useful for single-port full-stack
# debugging. In production this is automatic.
# MODELHARBOR_SERVE_WEB=1
